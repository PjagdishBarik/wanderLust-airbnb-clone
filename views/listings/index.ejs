
<% layout("/layouts/boilerplate") %>
<%
  const currentSelectedCategory =
    typeof locals !== "undefined" && locals.selectedCategory
      ? locals.selectedCategory
      : null;
  const categoryLabels = {
    trending: "Trending",
    bed: "Bed",
    iconic: "Iconic",
    mountain: "Mountain",
    pool: "Pool",
    camping: "Camping",
    farms: "Farms",
    snow: "Snow",
    desert: "Desert"
  };
  const activeCategoryLabel = currentSelectedCategory
    ? categoryLabels[currentSelectedCategory]
    : null;
%>
<div id="filters">
  <div class="filter-group">
    <div class="filter">
        <a href="/listings?category=trending" class="<%= currentSelectedCategory === 'trending' ? 'active-filter' : '' %>">
          <div>
            <i class="fa-solid fa-fire"></i>
        </div>
        <p>Trending</p>
        </a>
    </div>

     <div class="filter">
       <a href="/listings?category=bed" class="<%= currentSelectedCategory === 'bed' ? 'active-filter' : '' %>"> 
        <div>
            <i class="fa-solid fa-bed"></i>
        </div>
        <p>Bed</p></a>
    </div>

  <div class="filter">
       <a href="/listings?category=iconic" class="<%= currentSelectedCategory === 'iconic' ? 'active-filter' : '' %>">
         <div>
            <i class="fa-solid fa-mountain-city"></i>
        </div>
         <p>Iconic</p>
       </a>
    </div>

    <div class="filter">
       <a href="/listings?category=mountain" class="<%= currentSelectedCategory === 'mountain' ? 'active-filter' : '' %>">
         <div>
            <i class="fa-solid fa-mountain"></i>
        </div>
        <p>Mountain</p>
       </a>
    </div>

  <div class="filter">
        <a href="/listings?category=pool" class="<%= currentSelectedCategory === 'pool' ? 'active-filter' : '' %>">
          <div>
            <i class="fa-solid fa-person-swimming"></i>
        </div>
        <p>Pool</p>
        </a>
    </div>

   <div class="filter">
      <a href="/listings?category=camping" class="<%= currentSelectedCategory === 'camping' ? 'active-filter' : '' %>">
          <div>
       <i class="fa-solid fa-mountain-sun"></i>
        </div>
        <p>Camping</p>
      </a>
    </div>

    <div class="filter">
      <a href="/listings?category=farms" class="<%= currentSelectedCategory === 'farms' ? 'active-filter' : '' %>">
          <div>
           <i class="fa-solid fa-cow"></i>
        </div>
        <p>Farms</p>
      </a>
    </div>

   <div class="filter">
       <a href="/listings?category=snow" class="<%= currentSelectedCategory === 'snow' ? 'active-filter' : '' %>">
         <div>
          <i class="fa-solid fa-snowflake"></i>
        </div>
        <p>Snow</p>
       </a>
    </div>

  <div class="filter">
     <a href="/listings?category=desert" class="<%= currentSelectedCategory === 'desert' ? 'active-filter' : '' %>">
         <div>
          <i class="fa-solid fa-ice-cream"></i>
        </div>
        <p>Desert</p>
     </a>
    </div>
  </div>
 
   <div class="tax-toggle">
    <div class="form-check form-switch m-0">
      <input
        class="form-check-input"
        type="checkbox"
        role="switch"
        id="switchCheckDefault"
      >
      <label class="form-check-label" for="switchCheckDefault">
        Display total after taxes
      </label>
    </div>
  </div>
</div>

    <!-- <form method="GET" action="/listings/new">
      <button>Create New Listing</button>
    </form> -->
<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 mt-2 listings-grid">

      <% if (allListings.length === 0) { %>
        
        <div class="alert alert-info col-12" role="alert">
          <%= activeCategoryLabel ? `No hotels available in ${activeCategoryLabel}.` : "No listings available." %>
        </div>
      <% } %>
     <% for(let listing of allListings) { %>
      <a href="/listings/<%= listing._id %>" class="listing-link col">

    <div class="card listing-card" >
  <% if (listing.image && listing.image.url) { %>
    <img src="<%= listing.image.url %>" 
    class="card-img-top"
     alt="listing_image">
    
  <% } else { %>
    <img src="https://images.unsplash.com/photo-1625505826533-5c80aca7d157?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTJ8fGdvYXxlbnwwfHwwfHx8MA%3D%3D&auto=format&fit=crop&w=800&q=60" class="card-img-top" alt="default_image">
    <div class="card-img-overlay"></div>
  <% } %>
<div class="card-body">
    <p class="card-text">
      <b><%= listing.title %></b><br>
   &#8377; 
<span class="price" data-base="<%= listing.price %>">
  <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
</span>
/Night
<i class="class-info" style="display:none;"> (incl. 18% GST)</i>

    </p>
  </div>
</div>
</a>
 <% } %>
</div>
<script>
  const taxSwitch = document.getElementById("switchCheckDefault");
  const prices = document.getElementsByClassName("price");
  const taxInfos = document.getElementsByClassName("class-info");

  function updatePrices(showTax) {
    for (let i = 0; i < prices.length; i++) {
      const baseValue = prices[i].getAttribute("data-base");
      const basePrice = Number(baseValue);

      if (!Number.isFinite(basePrice)) {
        prices[i].innerText = "N/A";
        if (taxInfos[i]) taxInfos[i].style.display = "none";
        continue;
      }

      if (showTax) {
        const withTax = Math.round(basePrice * 1.18);
        prices[i].innerText = withTax.toLocaleString("en-IN");
        if (taxInfos[i]) taxInfos[i].style.display = "inline";
      } else {
        prices[i].innerText = basePrice.toLocaleString("en-IN");
        if (taxInfos[i]) taxInfos[i].style.display = "none";
      }
    }
  }

  if (taxSwitch) {
    taxSwitch.addEventListener("change", () => updatePrices(taxSwitch.checked));
    updatePrices(taxSwitch.checked);
  }

</script>
