<% layout("/layouts/boilerplate") %>

<script>
  const mapToken = "<%= process.env.MAPBOX_TOKEN %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="container listing-show-page mt-4">
  <% if (!listing) { %>
    <div class="alert alert-danger">Listing not found!</div>
  <% } else { %>
    <div class="row">
      <div class="col-md-10 col-xl-8 mx-auto">

        <!-- Listing Info -->
        <h2 class="mb-3"><%= listing.title %></h2>

        <div class="card mb-4 shadow listing-card">
          <% if (listing.image && listing.image.url) { %>
            <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>">
          <% } else { %>
            <img src="https://images.unsplash.com/photo-1625505826533-5c80aca7d157?auto=format&fit=crop&w=800&q=60" 
                 class="card-img-top" alt="Default Hotel Image">
          <% } %>

          <div class="card-body listing-show-body">
            <h5 class="card-title"><%= listing.title %></h5>
            <p><strong>Owner:</strong> <%= listing.owner.username %></p>
            <p><%= listing.description %></p>

            <div class="row">
              <div class="col-md-6">
                <p><strong>Location:</strong> <%= listing.location %></p>
                <p><strong>Country:</strong> <%= listing.country %></p>
              </div>
              <div class="col-md-6 text-md-end">
                <p><strong>Price:</strong> $<%= listing.price %> /night</p>
                
                <!-- ❤️ LIKE BUTTON -->
                <button id="likeButton" class="like-btn mt-2 <%= isLiked ? 'liked' : '' %>" 
                        data-listing-id="<%= listing._id %>"
                        <%= !currentUser ? 'disabled' : '' %>>
                  <i class="far fa-heart <%= isLiked ? 'fas' : '' %> heart-icon"></i>
                  <span class="like-count ms-1"><%= listing.likes ? listing.likes.length : 0 %></span>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Like Button Styles & JS -->
        <style>
          .like-btn {
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: #ddd;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
          }
          .like-btn:hover {
            transform: scale(1.1);
            color: #ff4757;
          }
          .like-btn.liked {
            color: #ff4757;
          }
          .like-btn.liked .heart-icon {
            animation: heartbeat 0.6s ease-in-out;
          }
          .like-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
          }
          @keyframes heartbeat {
            0% { transform: scale(1); }
            14% { transform: scale(1.3); }
            28% { transform: scale(1); }
            42% { transform: scale(1.3); }
            70% { transform: scale(1); }
          }
        </style>

        <script>
          // document.addEventListener('DOMContentLoaded', function() {
          //   const likeBtn = document.getElementById('likeButton');
          //   if (!likeBtn || !currentUser) return;

          //   likeBtn.addEventListener('click', async function(e) {
          //     e.preventDefault();
              
          //     const listingId = this.dataset.listingId;
          //     const isLiked = this.classList.contains('liked');
          //     const method = isLiked ? 'DELETE' : 'POST';
              
          //     try {
          //       const response = await fetch(`/listings/${listingId}/like`, {
          //         method: method,
          //         headers: { 'Content-Type': 'application/json' }
          //       });
                
          //       if (response.ok) {
          //         const data = await response.json();
                  
          //         // Update UI
          //         this.classList.toggle('liked', data.liked);
          //         const heartIcon = this.querySelector('.heart-icon');
          //         heartIcon.className = `fa-heart ${data.liked ? 'fas' : 'far'} heart-icon`;
          //         this.querySelector('.like-count').textContent = data.count;
                  
          //         // Animate
          //         if (data.liked) {
          //           heartIcon.style.animation = 'heartbeat 0.6s ease-in-out';
          //           setTimeout(() => heartIcon.style.animation = '', 600);
          //         }
          //       }
          //     } catch (error) {
          //       console.error('Like toggle failed:', error);
          //     }
          //   });
          // });
        </script>

        <!-- FIXED Edit/Delete Buttons with DEBUG -->
     
        <div class="alert alert-warning mb-3">
          <strong>🔍 DEBUG INFO:</strong><br>
          <% if (!currentUser) { %>
            ❌ No currentUser - <a href="/login">Log in</a> as owner to see buttons
          <% } else { %>
            ✅ Logged in: <%= currentUser.username %><br>
            <% if (!listing.owner || !listing.owner._id.equals(currentUser._id)) { %>
              ❌ Not listing owner (Owner: <%= listing.owner.username %>)<br>
              Owner ID: <%= listing.owner._id %><br>
              Your ID: <%= currentUser._id %>
            <% } else { %>
              ✅ You ARE the owner! Buttons below 👇
            <% } %>
          <% } %>
        </div>

        <% if (currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
          <div class="d-flex justify-content-between mb-4 p-3 listing-owner-actions" 
               style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); 
                      color: white; border-radius: 15px; box-shadow: 0 8px 25px rgba(102,126,234,0.3);">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-light btn-lg shadow-lg me-2">
              <i class="fas fa-edit me-1"></i>Edit Listing
            </a>
            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="listing-owner-delete-form">
              <button type="submit" class="btn btn-outline-light btn-lg shadow-lg" 
                      onclick="return confirm('⚠️ Delete this listing permanently?')">
                <i class="fas fa-trash-alt me-1"></i>Delete Listing
              </button>
            </form>
          </div>
          <div class="alert alert-success">
            ✅ Buttons fixed! Log in as owner to test. Remove DEBUG div above when done.
          </div>
        <% } %>

        <!-- Book Button -->
        <div class="text-center mb-5">
          <a href="/listings/<%= listing._id %>/book" class="btn btn-primary btn-lg">Book Now</a>
        </div>

        <hr>

        <div class="review-section">
          <h4>Leave a Review</h4>

          <form action="/listings/<%= listing._id %>/reviews" method="POST">
            <label class="review-label">Rating</label>
            <fieldset class="starability-growRotate">
              <input type="radio" id="rate1" name="review[rating]" value="1" />
              <label for="rate1" title="Terrible">1 star</label>
              <input type="radio" id="rate2" name="review[rating]" value="2" />
              <label for="rate2" title="Not good">2 stars</label>
              <input type="radio" id="rate3" name="review[rating]" value="3" />
              <label for="rate3" title="Average">3 stars</label>
              <input type="radio" id="rate4" name="review[rating]" value="4" />
              <label for="rate4" title="Very good">4 stars</label>
              <input type="radio" id="rate5" name="review[rating]" value="5" />
              <label for="rate5" title="Amazing">5 stars</label>
            </fieldset>

            <label for="comment" class="review-label">Comment</label>
            <textarea id="comment" name="review[comment]" class="form-control" required></textarea><br>
            <button type="submit" class="btn btn-outline-dark btn-review-submit">Submit</button>
          </form>
        </div>

        <hr>

        <!-- All Reviews -->
        <h5 class="mb-5">All Reviews</h5>
        <div class="container px-0">
          <div class="row">
            <% if (listing.reviews.length > 0) { %>
              <% listing.reviews.forEach(review => { %>
                <div class="col-md-6 mb-5">
                  <div class="card h-100 shadow-sm">
                    <div class="card-body">
                      <!-- ⭐ FIXED STAR DISPLAY -->
                      <div class="starability-result" data-rating="<%= review.rating %>"></div>
                      <p>RAW RATING: <%= review.rating %></p>
                      <p><%= review.comment %></p>
                    </div>

                    <% if (currentUser && currentUser._id.equals(review.author._id)) { %>
                      <form method="POST"
                            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                            class="p-3">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">Delete</button>
                      </form>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p>No reviews yet. Be the first to leave one!</p>
            <% } %>
          </div>
        </div>

        <hr>

        <!-- Map -->
        <div class="mb-5">
          <h3><b>Where you'll be</b></h3>
          <div id="map" class="listing-map"></div>
        </div>

      </div>
    </div>
  <% } %>
</div>

<script src="/js/map.js"></script>

